# Copy this file to .env and fill in your actual values
# NEVER commit .env to GitHub

# PostgreSQL connection (from Supabase/Neon dashboard)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# JWT secret - use any long random string (e.g. generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=replace_this_with_a_long_random_secret_string

# Server port
PORT=3001

# Frontend URL (for CORS) - change to your deployed frontend URL in production
FRONTEND_URL=http://localhost:8080
